APP_NAME=Plazmasoft
APP_ENV=production
APP_KEY=base64:GENERATE_WITH_php_artisan_key_generate
APP_DEBUG=false
APP_URL=https://plazmasoft.com

LOG_CHANNEL=stack
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=u411863014_plazmasoft
DB_USERNAME=u411863014_plazmasoft
DB_PASSWORD=YOUR_DB_PASSWORD_HERE

CACHE_STORE=database
SESSION_DRIVER=database
SESSION_LIFETIME=120
QUEUE_CONNECTION=database

MAIL_MAILER=smtp
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=587
MAIL_USERNAME=info@plazmasoft.com
MAIL_PASSWORD=YOUR_MAIL_PASSWORD_HERE
MAIL_ENCRYPTION=tls
COMPANY_EMAIL="info@plazmasoft.com"
MAIL_FROM_ADDRESS="${COMPANY_EMAIL}"
MAIL_FROM_NAME="${APP_NAME}"

# Used to protect post-deploy.php endpoint -- must match deploy.config.ps1 DEPLOY_SECRET
DEPLOY_SECRET=change-this-to-a-long-random-string

FILESYSTEM_DISK=public
